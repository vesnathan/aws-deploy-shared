{
  "name": "@vesnathan/aws-deploy-shared",
  "version": "1.0.6",
  "description": "Shared utilities and types for AWS deployment projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/vesnathan/shared.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn build"
  },
  "exports": {
    "./deploy-utils": {
      "types": "./dist/deploy-utils/index.d.ts",
      "default": "./deploy-utils/index.ts"
    },
    "./deploy-utils/custom-resources": {
      "types": "./dist/deploy-utils/custom-resources/index.d.ts",
      "default": "./deploy-utils/custom-resources/index.ts"
    },
    "./deploy-utils/custom-resources/s3-bucket-cleanup": {
      "types": "./dist/deploy-utils/custom-resources/s3-bucket-cleanup.d.ts",
      "default": "./deploy-utils/custom-resources/s3-bucket-cleanup.ts"
    },
    "./deploy-utils/custom-resources/cognito-domain-cleanup": {
      "types": "./dist/deploy-utils/custom-resources/cognito-domain-cleanup.d.ts",
      "default": "./deploy-utils/custom-resources/cognito-domain-cleanup.ts"
    },
    "./deploy-utils/custom-resources/route53-record-upsert": {
      "types": "./dist/deploy-utils/custom-resources/route53-record-upsert.d.ts",
      "default": "./deploy-utils/custom-resources/route53-record-upsert.ts"
    },
    "./types": {
      "types": "./dist/src/types/index.d.ts",
      "default": "./src/types/index.ts"
    },
    "./cognito": {
      "types": "./dist/cognito/index.d.ts",
      "default": "./cognito/index.ts"
    },
    "./subscription": {
      "types": "./dist/subscription/index.d.ts",
      "default": "./subscription/index.ts"
    },
    "./subscription/types": {
      "types": "./dist/subscription/types/index.d.ts",
      "default": "./subscription/types/index.ts"
    },
    "./subscription/lambda": {
      "types": "./dist/subscription/lambda/index.d.ts",
      "default": "./subscription/lambda/index.ts"
    },
    "./subscription/frontend": {
      "types": "./dist/subscription/frontend/index.d.ts",
      "default": "./subscription/frontend/index.ts"
    },
    "./subscription/config": {
      "types": "./dist/subscription/config/index.d.ts",
      "default": "./subscription/config/index.ts"
    }
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1015.0",
    "@aws-sdk/client-appsync": "^3.1004.0",
    "@aws-sdk/client-cloudformation": "^3.1004.0",
    "@aws-sdk/client-cloudfront": "^3.1004.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1004.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/client-iam": "^3.1004.0",
    "@aws-sdk/client-lambda": "^3.1004.0",
    "@aws-sdk/client-route-53": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-secrets-manager": "^3.1004.0",
    "@aws-sdk/client-ses": "^3.1004.0",
    "@aws-sdk/client-sts": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@aws-sdk/types": "^3.973.6",
    "@inquirer/figures": "^2.0.4",
    "@inquirer/prompts": "^8.3.2",
    "@vesnathan/aws-deploy-shared": "1.0.6",
    "archiver": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "esbuild": "^0.27.0",
    "inquirer": "^13.3.2",
    "mime-types": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.0",
    "@types/inquirer": "^9.0.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
